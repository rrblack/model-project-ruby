<section class="mx-auto justify-center md:w-120 min-h-screen overflow-hidden">
  <div class="mt-20 p-4"><%= link_to "← トップへ戻る", "/", class: "text-sm text-gray-500 hover:text-black" %></div> 
<div class="flex flex-col md:border md:mt-4 p-10 rounded overflow-hidden">
<h1 class="text-xl font-bold mt-4 p-4 gap-2 text-center">お問い合わせ </h1>
<%= form_with url: "/contact", method: :post do %>
<div class="mb-4 p-4 overflow-hidden">
<label class="text-md md:mb-1"> お名前</label>
<%= text_field_tag :name, nil, class:"w-full border p-2 rounded", required: true %> 
</div>


<div class="mb-4 p-4 overflow-hidden">
<label class="text-md mb-1"> メール</label>
<%= email_field_tag :email, nil, class:"w-full border p-2 rounded", required: true %>
</div>

<div class="mb-4 p-4  overflow-hidden">
<label class="text-md mb-1">ご要件</label>
<%= text_area_tag :message, nil, class:"border p-2 rounded w-full h-32", required: true %>
</div>

<%= submit_tag "送信", class:"border rounded-xl h-10 bg-black transition-colors duration-500 hover:bg-gray-700 w-full text-white cursor-pointer" %>
<% if notice %>
    <div class="text-green-400 text-2xl border p-4 mb-4 mt-4 ">
      <%= notice %> 
      </div>
    <%end%>
<%end%>
</div>
</section>

