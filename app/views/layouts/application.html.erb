<!DOCTYPE html>
<html>
  <head>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Noto+Serif+JP:wght@300;400;500&family=Montserrat:wght@200;300;400&family=Playfair+Display:ital,wght@0,400;0,700;1,400&display=swap" rel="stylesheet">
    <%= stylesheet_link_tag "https://unpkg.com/aos@2.3.1/dist/aos.css" %>
    <title><%= content_for(:title) || "倉沢りな ポートフォリオサイト" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Model Project">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app %>
    <%= javascript_importmap_tags %>
  </head>
  <body>
    <header data-controller="nav" class="z-99 flex justify-center mx-auto md:p-3 md:p-6 p-2 w-full md:h-14 md:border md:bg-black fixed top-0">
      <div class="text-white text-md relative">
        <nav class="-mt-3">
          <ul data-nav-target="menu" class="fixed left-0 flex-col hidden md:!flex md:flex-row items-center justify-center text-center bg-black md-bg-transparent md:gap-8 gap-12">
            <li class="p-4 cursor-pointer transition-colors duration-500 hover:bg-white md:px-4 md:py-1 hover:text-black rounded-sm w-screen md:w-auto"> <%= link_to "自己紹介","/#intro"%></li>
            <span class="hidden md:!flex text-gray-500">|</span>
            <li class="p-4 cursor-pointer transition-colors duration-500 hover:bg-white md:px-4 md:py-1 hover:text-black rounded-sm w-screen md:w-auto"> <%= link_to "モデル","/#model"%></li>
            <span class="hidden md:!flex text-gray-500">|</span>
            <li class="p-4 cursor-pointer transition-colors duration-500 hover:bg-white md:px-4 md:py-1 hover:text-black rounded-sm w-screen md:w-auto">
              <%= link_to "/#doukai" do %>
                <span class="md:hidden">司会</span>
                <span class="hidden md:block">司会リポーター</span>
              <% end %>
            </li>
            <span class="hidden md:!flex text-gray-500">|</span>
            <li class="p-4 cursor-pointer transition-colors duration-500 hover:bg-white md:px-4 md:py-1 hover:text-black rounded-sm w-screen md:w-auto"><%= link_to "SNS","/#SNS" %></li>
            <span class="hidden md:!flex text-gray-500">|</span>
            <li class="p-4 cursor-pointer transition-colors duration-500 hover:bg-white md:px-4 md:py-1 hover:text-black rounded-sm w-screen md:w-auto"> <%= link_to "お問い合わせ", "/contact" %> </li>
          </ul>
        </nav>
      </div>
      <button data-action="click->nav#toggle" class="p-4 scale-150 cursor-pointer flex md:hidden text-white ml-auto">☰</button>
    </header>
    <main class="relative md:mt-14">
      <%= yield %>
    </main>
    <footer class="flex justify-center w-full h-40 bg-black items-end p-4  overflow-hidden">
    <div class="mx-auto text-center text-white md:text-sm text-sm">
    <p class="bottom-0"> © Copyright    |   Kurasa Rina   |   All Rights Reserved </p>
    </div>
  </footer>
  </body>
</html>
