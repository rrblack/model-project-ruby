  </div>
  </div>
  </div>
    <div class="mx-auto text-center text-white md:text-sm text-sm">
    <p class="bottom-0">  Copyright <%= Time.current.year %> |   Kurasa Rina   |   All Rights Reserved </p>
    </div>
  </footer>
  </body>
</html>
